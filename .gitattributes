# Set default line ending behaviour
* text=auto eol=lf

# Explicitly declare text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.prisma text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.woff2 binary
*.woff  binary
