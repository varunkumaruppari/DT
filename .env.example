# Daily Development Tracker — Environment Configuration
# Copy this file to .env (for root-level tools) and configure per-workspace:
#   apps/api/.env  — backend environment
#   apps/web/.env  — frontend environment

# ============================================================
# BACKEND — apps/api/.env
# ============================================================

NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://ddt_user:ddt_password@localhost:5433/ddt_db
JWT_SECRET=your-secret-here-minimum-32-characters
CORS_ORIGIN=http://localhost:5173

# ============================================================
# FRONTEND — apps/web/.env
# ============================================================

VITE_API_BASE_URL=http://localhost:3001

# ============================================================
# FUTURE MILESTONE VARIABLES (DO NOT CONFIGURE YET)
# These belong to later implementation milestones.
# ============================================================

# Milestone 02 — Authentication
# JWT_SECRET=your-secret-here-minimum-32-characters

# Milestone 05 — Web Push Notifications
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@yourdomain.com
